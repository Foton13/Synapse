# ──────────────────────────────────────────────
# Synapse — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to `.env` and fill in your values.
# cp .env.example .env

# ── LLM Provider ──────────────────────────────
# Supported: "ollama" (default, local) | "openai"
LLM_PROVIDER=ollama

# Ollama model name (used when LLM_PROVIDER=ollama)
OLLAMA_MODEL=llama3

# OpenAI API key (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# ── Neo4j ─────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── ChromaDB ──────────────────────────────────
CHROMA_DB_PATH=./data/chromadb
